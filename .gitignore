# Temporários de escritório / sistema
~$*.xlsx
~$*.docx
~$*.pptx
.DS_Store
Thumbs.db

# Python / uv
__pycache__/
*.pyc
.venv/
.uv/
.ruff_cache/

# Saídas de build de PDF intermediárias
*.aux
*.log
*.toc

# Intermediários regeneráveis pelos scripts/ (a partir dos .md):
# os .pdf são versionados; os .html/.svg de build, não — exceto o guia (que é fonte).
deliverables/*.html
!deliverables/guia-do-negocio.html
deliverables/assets/

# Originais de referência com PII — manter só local; versionar apenas as versões tarjadas
design/concurseiro/referencias/_originais/

# Saída do Playwright MCP (cruft de automação)
.playwright-mcp/
# Manifestos gerados na raiz (cópia versionada fica em design/concurseiro/pesquisa/fontes/)
/indigo_manifest.json
/hobonichi_manifest.json
# Imagens baixadas de concorrentes — reproduzíveis via *_manifest.json; não versionar (peso ~160MB)
design/concurseiro/pesquisa/capturas/
design/concurseiro/caderno-de-erros/referencias/

# Artefatos de debug/scratch dos mockups
design/concurseiro/planner-v1/mockups/*debug*

# Typst — intermediários de build (regeneráveis via render.py/finalize.py)
design/concurseiro/planner-v1/typst/*.pdf
!design/concurseiro/planner-v1/typst/planner-proto-pdfx1a.pdf
